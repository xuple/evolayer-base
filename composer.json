{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "xuple/evolayer-base",
    "description": "EvoLayer Base — AI agents, ontology, and premium React blocks for the Laravel React Inertia starter. Part of the EvoDevOps starter-kit family.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "evolayer",
        "evodevops",
        "xuple",
        "laravel",
        "inertia",
        "react",
        "ai",
        "ontology"
    ],
    "require": {
        "php": "^8.4",
        "laravel/framework": "^13.7",
        "laravel/ai": "^0.6.5",
        "inertiajs/inertia-laravel": "^3.0",
        "spatie/laravel-permission": "^7.4",
        "spatie/laravel-activitylog": "^5.0",
        "symfony/yaml": "^7.0|^8.0"
    },
    "require-dev": {
        "laravel/boost": "^2.2",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.6",
        "pestphp/pest-plugin-laravel": "^4.1",
        "spatie/laravel-medialibrary": "^11.22",
        "spatie/laravel-tags": "^4.11"
    },
    "suggest": {
        "spatie/laravel-medialibrary": "Required to enable contact attachment processing. Set EVOLAYER_BASE_FEATURE_CONTACT_ATTACHMENTS=true after install.",
        "spatie/laravel-tags": "Required to enable AI auto-tagging on form submissions during triage.",
        "cweagans/composer-patches": "Required for structured streaming on laravel/ai <=0.6.5. See patches/README.md."
    },
    "autoload": {
        "psr-4": {
            "Xuple\\EvoLayer\\Base\\": "src/",
            "Xuple\\EvoLayer\\Base\\Database\\Factories\\": "database/factories/",
            "Xuple\\EvoLayer\\Base\\Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "src/Compat/bootstrap.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Xuple\\EvoLayer\\Base\\Tests\\": "tests/",
            "Xuple\\EvoLayer\\Base\\Tests\\Fixtures\\": "tests/Fixtures/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Xuple\\EvoLayer\\Base\\BaseServiceProvider"
            ]
        }
    },
    "scripts": {
        "apply-patches": "@php scripts/apply-patches.php",
        "post-install-cmd": [
            "@apply-patches"
        ],
        "post-update-cmd": [
            "@apply-patches"
        ],
        "test": "vendor/bin/pest"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
